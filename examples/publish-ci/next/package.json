{
  "name": "rtk-esm-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rimraf .next/ dist/ node_modules/.tmp/tsconfig.tsbuildinfo next-env.d.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc",
    "serve-app": "yarn start",
    "lint": "eslint --config=$PROJECT_CWD/eslint.config.mjs $INIT_CWD",
    "test": "playwright test --config=playwright.config.ts",
    "format": "prettier --write \"./src/**/*.{ts,tsx}\" \"**/*.md\""
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "msw": "^2.14.6",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "serve": "^14.2.6",
    "typescript": "^6.0.3"
