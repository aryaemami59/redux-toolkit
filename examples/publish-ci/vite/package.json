{
  "name": "rtk-esm-vite-normal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist/ node_modules/.tmp/tsconfig.{app,node}.tsbuildinfo",
    "dev": "vite --config=vite.config.ts",
    "build": "tsc -b tsconfig.build.json && vite --config=vite.config.ts build",
    "preview": "vite --config=vite.config.ts preview",
    "serve-app": "serve -s dist",
    "test": "playwright test --config=playwright.config.ts",
    "format": "prettier --write \"./src/**/*.{ts,tsx}\" \"**/*.md\""
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "msw": "^2.14.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
