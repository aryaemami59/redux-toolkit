{
  "name": "expo-template-redux-typescript",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "android": "expo run:android",
    "build": "expo prebuild -p android && rnc-cli bundle --entry-file index.ts --bundle-output build/bundle.js --dev false --verbose --platform android --assets-dest build/assets",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "ios": "expo run:ios",
    "lint:fix": "eslint --config=eslint.config.mjs --fix .",
    "lint": "eslint --config=eslint.config.mjs .",
    "start": "expo start",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "web": "expo start --web"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "expo": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/jest-preset": "^0.85.3",
    "@react-native/metro-config": "^0.85.3",
    "@testing-library/react-native": "^14.0.0",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-x": "^5.8.13",
    "globals": "^17.6.0",
    "jest": "~29.7.0",
    "jest-expo": "^56.0.4",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "test-renderer": "^1.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "private": true
}
